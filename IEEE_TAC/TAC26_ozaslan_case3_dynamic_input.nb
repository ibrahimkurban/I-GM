Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"invConformal", "[", "z_", "]"}], " ", ":=", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "+", "z"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"1", "-", "z"}], ")"}]}], ")"}], "^", "2"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"hbgzi", " ", "=", " ", 
     RowBox[{"invConformal", "[", "qz", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"hb", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"hbgzi", "/.", 
        RowBox[{"z", "->", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"z", "/", "\[Gamma]"}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"-", "1"}], ")"}]}]}]}], "/.", "gammaSol"}], " ", "//", 
      "FullSimplify"}], "//", " ", "Flatten", " "}]}]}]}]], "Input",
