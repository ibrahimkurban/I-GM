Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"mA", ",", "mB", ",", "mC", ",", "mD"}], "}"}], "=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "i", ",", "A1", ",", "B1", ",", "C1", ",", "D1", ",", "A2", ",", "B2", 
        ",", "C2", ",", "D2"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A1", "=", 
        RowBox[{"{", 
         RowBox[{"{", 
