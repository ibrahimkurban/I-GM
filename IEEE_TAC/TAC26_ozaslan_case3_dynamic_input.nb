            "}"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"B2", "=", 
           RowBox[{"{", 
            RowBox[{"{", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"1", "-", 
               RowBox[{
                RowBox[{"Abs", "[", 
                 RowBox[{"zi", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "]"}], "^", "2"}]}], "]"}], 
             "}"}], "}"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"C2", "=", "B2"}], ";", "\[IndentingNewLine]", 
