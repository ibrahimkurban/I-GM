           RowBox[{"zi", "[", 
            RowBox[{"[", "1", "]"}], "]"}], "//", "Conjugate"}], "}"}], 
         "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"B1", "=", 
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", "-", 
            RowBox[{
             RowBox[{"Abs", "[", 
              RowBox[{"zi", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "]"}], "^", "2"}]}], "]"}], 
          "}"}], "}"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"C1", "=", "B1"}], ";", "\[IndentingNewLine]", 
