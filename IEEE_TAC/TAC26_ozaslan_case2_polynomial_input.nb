Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"V", ",", "mI"}], "}"}], "=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"M", ",", "vp", ",", "rhs", ",", "i"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"mI", "=", 
        RowBox[{"IdentityMatrix", "[", "n", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"M", "=", 
        RowBox[{"mI", "-", 
         RowBox[{"\[Gamma]", "*", "mA"}]}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"Vi", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "n"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Vi", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}], "=", 
        RowBox[{"mB", " ", "//", "Flatten"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"Do", "[", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"vp", "=", 
           RowBox[{"Vi", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", 
              RowBox[{"i", "-", "1"}]}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{"rhs", "=", 
           RowBox[{"If", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"i", "==", "2"}], ",", "vp", ",", "\[IndentingNewLine]", 
             
             RowBox[{
              RowBox[{"(", 
               RowBox[{"i", "-", "2"}], ")"}], "*", 
              RowBox[{"mA", ".", "vp"}]}]}], "\[IndentingNewLine]", "]"}]}], ";",
           "\[IndentingNewLine]", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"Vi", "[", 
            RowBox[{"[", 
             RowBox[{"All", ",", "i"}], "]"}], "]"}], "=", 
           RowBox[{
            RowBox[{"LinearSolve", "[", 
             RowBox[{"M", ",", "rhs"}], "]"}], " ", "//", " ", "Flatten"}]}], 
          ";"}], "\[IndentingNewLine]", ",", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{"i", ",", "2", ",", "n"}], "}"}]}], "\[IndentingNewLine]", 
        "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"Vi", ",", " ", "mI"}], "}"}]}]}], "\[IndentingNewLine]", 
