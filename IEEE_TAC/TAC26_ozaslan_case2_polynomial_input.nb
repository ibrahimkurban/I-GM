Cell[CellGroupData[{

Cell["Blaschke product using Takenaka-Malmquist basis", "Subtitle",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.980101607019125*^9, 3.98010163807727*^9}, {
  3.9801019592197323`*^9, 3.980101968535273*^9}},
 Background->RGBColor[
  0.4, 0.6, 1, 0.33],ExpressionUUID->"6e46eec5-9e36-4db8-9b4c-64cd8445bee2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"mA", ",", "mB", ",", "mC", ",", "mD"}], "}"}], "=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"rb", ",", "i", ",", "j"}], "}"}], ",", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{"rb", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", 
          RowBox[{"\[Gamma]", "^", "2"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"mA", "=", 
        RowBox[{"Table", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Which", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"i", "<", "j"}], ",", "0", ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"i", "==", "j"}], "&&", 
             RowBox[{"i", "==", "1"}]}], ",", "0", ",", "\[IndentingNewLine]", 
            RowBox[{"i", "==", "j"}], ",", "\[Gamma]", ",", 
            "\[IndentingNewLine]", 
            RowBox[{"j", "==", "1"}], ",", 
            RowBox[{"rb", "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"-", "\[Gamma]"}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"i", "-", "2"}], ")"}]}]}], ",", "\[IndentingNewLine]",
             "True", ",", 
            RowBox[{
             RowBox[{"rb", "^", "2"}], "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"-", "\[Gamma]"}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"i", "-", "j", "-", "1"}], ")"}]}]}]}], 
           "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "\[IndentingNewLine]", 
         "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"mB", "=", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"{", "1", "}"}], "}"}], ",", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", 
            RowBox[{"{", 
             RowBox[{"num", ",", "1"}], "}"}]}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"mC", "=", 
        RowBox[{"Table", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"j", "==", "1"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "\[Gamma]"}], ")"}], "^", "num"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"rb", "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"-", "\[Gamma]"}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"n", "-", "j"}], ")"}]}]}]}], "\[IndentingNewLine]", 
           "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "\[IndentingNewLine]", 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"mC", "=", 
        RowBox[{"{", "mC", "}"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"mD", "=", 
        RowBox[{"{", 
         RowBox[{"{", "0", "}"}], "}"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"mA", ",", "mB", ",", "mC", ",", "mD"}], "}"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"mA", " ", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{"mB", " ", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{"mC", " ", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{"mD", " ", "//", "MatrixForm"}]}], "Input",
 CellChangeTimes->{{3.980101975129251*^9, 3.980102269242449*^9}, {
