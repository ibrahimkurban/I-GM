Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"mA", ",", "mB", ",", "mC", ",", "mD"}], "}"}], "=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"rb", ",", "i", ",", "j"}], "}"}], ",", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{"rb", "=", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"1", "-", 
          RowBox[{"\[Gamma]", "^", "2"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"mA", "=", 
        RowBox[{"Table", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"Which", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"i", "<", "j"}], ",", "0", ",", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"i", "==", "j"}], "&&", 
             RowBox[{"i", "==", "1"}]}], ",", "0", ",", "\[IndentingNewLine]", 
            RowBox[{"i", "==", "j"}], ",", "\[Gamma]", ",", 
            "\[IndentingNewLine]", 
            RowBox[{"j", "==", "1"}], ",", 
            RowBox[{"rb", "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"-", "\[Gamma]"}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"i", "-", "2"}], ")"}]}]}], ",", "\[IndentingNewLine]",
             "True", ",", 
            RowBox[{
             RowBox[{"rb", "^", "2"}], "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"-", "\[Gamma]"}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"i", "-", "j", "-", "1"}], ")"}]}]}]}], 
           "\[IndentingNewLine]", "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "n"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "\[IndentingNewLine]", 
         "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"mB", "=", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"{", "1", "}"}], "}"}], ",", 
          RowBox[{"ConstantArray", "[", 
           RowBox[{"0", ",", 
            RowBox[{"{", 
             RowBox[{"num", ",", "1"}], "}"}]}], "]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", "\[IndentingNewLine]", 
       RowBox[{"mC", "=", 
        RowBox[{"Table", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"If", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"j", "==", "1"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"-", "\[Gamma]"}], ")"}], "^", "num"}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"rb", "*", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"-", "\[Gamma]"}], ")"}], "^", 
              RowBox[{"(", 
               RowBox[{"n", "-", "j"}], ")"}]}]}]}], "\[IndentingNewLine]", 
           "]"}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "\[IndentingNewLine]", 
         "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"mC", "=", 
        RowBox[{"{", "mC", "}"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"mD", "=", 
        RowBox[{"{", 
         RowBox[{"{", "0", "}"}], "}"}]}], ";", "\[IndentingNewLine]", 
       "\[IndentingNewLine]", 
       RowBox[{"{", 
        RowBox[{"mA", ",", "mB", ",", "mC", ",", "mD"}], "}"}]}]}], 
     "\[IndentingNewLine]", "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"mA", " ", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{"mB", " ", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{"mC", " ", "//", "MatrixForm"}], "\[IndentingNewLine]", 
 RowBox[{"mD", " ", "//", "MatrixForm"}]}], "Input",
