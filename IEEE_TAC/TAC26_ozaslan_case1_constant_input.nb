Cell["Blaschke product using Takenaka-Malmquist basis", "Subtitle",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.980101607019125*^9, 3.98010163807727*^9}, {
  3.9801019592197323`*^9, 3.980101968535273*^9}},
